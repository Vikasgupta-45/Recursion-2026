# Copy to .env (never commit .env)
# Groq (free tier) — https://console.groq.com
GROQ_API_KEY=
# Optional; see Groq docs for current model ids
GROQ_CHAT_MODEL=llama-3.1-8b-instant

# YouTube Data API v3 — https://console.cloud.google.com/apis/credentials
# File must live in backend/.env (next to main.py), then restart uvicorn.
# Also accepted: YOUTUBE_DATA_API_KEY, YT_API_KEY (same value).
YOUTUBE_API_KEY=

# Optional OpenAI if not using Groq
OPENAI_API_KEY=

# Free Gemini (AI Studio) — vision for thumbnail CTR when Groq vision fails / unavailable
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional override (default gemini-2.0-flash)
# GEMINI_VISION_MODEL=gemini-2.0-flash

# Optional: Groq vision model id for thumbnail scoring (default llama-3.2-11b-vision-preview)
# GROQ_VISION_MODEL=
